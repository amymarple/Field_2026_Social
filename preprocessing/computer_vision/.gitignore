# transient / generated artifacts
scratch/
tracks/
outputs/
dataset/          # sampled frames + labels (large; keep data off git)
runs/             # ultralytics training runs / weights / plots
__pycache__/
*.pyc

# model weights (downloaded on demand)
*.pt

